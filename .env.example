# ── GyroCompass — Environment Configuration ───────────────────────────────────
#
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# The .env file is gitignored — never commit secrets to version control.
#
# REQUIRED: Set at least one LLM API key. GyroCompass uses LLMs to:
#   • Analyze changed code semantically during drift detection
#   • Evaluate check_compliance requests against natural-language rules
#   • Summarize drift reports in the PR comment
#
# OPTIONAL: All other settings have sensible defaults for local development.
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM Provider ──────────────────────────────────────────────────────────────
#
# Set GYRO_LLM_PROVIDER to one of: openai | anthropic | ollama | custom
# GyroCompass auto-selects the provider based on which keys are present,
# but the explicit setting is respected if provided.
#
GYRO_LLM_PROVIDER=openai


# ── OpenAI ────────────────────────────────────────────────────────────────────
#
# Required when GYRO_LLM_PROVIDER=openai (or when no provider is explicitly set
# and OPENAI_API_KEY is the only key present).
#
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini        # Default: gpt-4o-mini. Use gpt-4o for higher accuracy.
# OPENAI_BASE_URL=                # Override for OpenAI-compatible APIs (see Custom section)


# ── Anthropic ─────────────────────────────────────────────────────────────────
#
# Required when GYRO_LLM_PROVIDER=anthropic.
#
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6   # Default: claude-sonnet-4-6


# ── Ollama (local, privacy-first) ─────────────────────────────────────────────
#
# Use Ollama to run analysis entirely on-premises — no data leaves your machine.
# Requires a running Ollama instance: https://ollama.com
#
# GYRO_LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434   # Default: http://localhost:11434
# OLLAMA_MODEL=llama3.2                   # Default: llama3.2. Use llama3.1:70b for better results.


# ── Custom / Self-Hosted LLM Endpoint ─────────────────────────────────────────
#
# Any OpenAI-compatible REST endpoint: Azure OpenAI, Together AI, Groq, vLLM,
# LM Studio, or any other provider that speaks the OpenAI chat completions API.
#
# GYRO_LLM_PROVIDER=custom
# GYRO_LLM_BASE_URL=https://your-deployment.openai.azure.com/
# GYRO_LLM_API_KEY=your-api-key
# GYRO_LLM_MODEL=your-model-name


# ── Database ──────────────────────────────────────────────────────────────────
#
# SQLite (default) — zero config, perfect for local dev and single-user setups.
# PostgreSQL        — recommended for team deployments (use docker-compose --profile postgres).
#
# SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///./data/gyrocompass.db

# PostgreSQL (team deployment):
# DATABASE_URL=postgresql+asyncpg://gyrocompass:gyrocompass@localhost:5432/gyrocompass

# PostgreSQL connection details (used by docker-compose postgres profile):
# POSTGRES_DB=gyrocompass
# POSTGRES_USER=gyrocompass
# POSTGRES_PASSWORD=gyrocompass
# POSTGRES_PORT=5432


# ── Redis ─────────────────────────────────────────────────────────────────────
#
# Optional. When set, GyroCompass caches drift report results in Redis to avoid
# re-running LLM analysis on unchanged files.
#
# REDIS_URL=redis://localhost:6379/0
# REDIS_PORT=6379


# ── API Server ────────────────────────────────────────────────────────────────
#
API_PORT=7700
API_HOST=0.0.0.0

# Secret key used to sign JWT tokens and session cookies.
# Generate a secure value with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change-me-in-production

# Comma-separated list of allowed CORS origins for the web dashboard.
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com


# ── Web Dashboard ─────────────────────────────────────────────────────────────
#
WEB_PORT=3000

# URL the browser uses to reach the API (must be publicly reachable if deployed).
NEXT_PUBLIC_API_URL=http://localhost:7700

# Path prefix for the web dashboard if hosted under a subpath (e.g. /gyrocompass).
# NEXT_PUBLIC_BASE_PATH=


# ── MCP Server ────────────────────────────────────────────────────────────────
#
# The MCP server is embedded in the gyrocompass CLI and launched automatically
# by Claude Code (or any MCP client) when configured. You typically do not need
# to change these settings.
#
# Transport: stdio (default for Claude Code) | streamable-http (for remote clients)
# MCP_TRANSPORT=stdio
# MCP_HOST=localhost
# MCP_PORT=7701


# ── Indexer ───────────────────────────────────────────────────────────────────
#
# Controls how GyroCompass indexes your repository to build the architecture map.
#
# Absolute path to the repository to analyze.
# Defaults to the current working directory when running gyro index.
# TARGET_REPO_PATH=/path/to/your/repo

# Path used inside Docker (mount point for the REPOS_ROOT volume)
# REPOS_ROOT=./

# Maximum file size (in bytes) to parse during indexing.
# Files larger than this are skipped to avoid excessive LLM token usage.
MAX_FILE_SIZE_BYTES=500000

# Number of parallel workers for the indexer.
# Increase for large monorepos; decrease to reduce LLM API costs.
INDEX_WORKERS=4


# ── GitHub Integration ────────────────────────────────────────────────────────
#
# Required only if you want GyroCompass to post PR comments via the GitHub API
# directly (as opposed to using the GitHub Actions workflow which handles this).
#
# GITHUB_TOKEN=ghp_...
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=


# ── Graph Engine (deep code graph — optional, Phase 2) ──
#
# The deep code-graph engine builds a Memgraph knowledge graph of your codebase
# (functions, classes, modules + CALLS / IMPORTS / INHERITS edges) and an
# optional Qdrant vector index for semantic code search.
#
# Start the backing services with: docker compose --profile graph up
#
GYRO_GRAPH_BACKEND=lite        # "lite" (NetworkX, default) | "graph" (Memgraph+Qdrant)
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_BATCH_SIZE=1000
QDRANT_URL=                    # e.g. http://localhost:6333 ; blank = embedded mode
QDRANT_PATH=./.qdrant_gyro
GYRO_SEMANTIC_ENABLED=false    # true requires torch + transformers (heavy)
EMBEDDING_MODEL=microsoft/unixcoder-base


# ── Telemetry ─────────────────────────────────────────────────────────────────
#
# GyroCompass does NOT collect telemetry by default. Set to true to opt in to
# anonymous usage metrics (no code, no secrets, no file contents are ever sent).
# This helps the maintainers prioritize which features to build next.
#
TELEMETRY_ENABLED=false
